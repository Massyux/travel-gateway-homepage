# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code local settings (may contain machine-specific permissions)
.claude/settings.local.json

/src/generated/prisma

# SQLite database (homepage phase 2 admin space)
*.db
*.db-journal

# admin-uploaded images (homepage phase 2 admin space)
/public/uploads/*
!/public/uploads/.gitkeep
